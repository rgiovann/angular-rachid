{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/*.css",
          "/*.js",
          "/favicon.ico",
          "/favicon-32x32.png",
          "/apple-touch-icon.png",
          "/manifest.webmanifest"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/*.png", "/*.svg", "/*.jpg", "/*.jpeg", "/*.webp", "/*.ico"]
      }
    }
  ]
}
